<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.yonyoucloud.fi.cmp.mapper.UserMasterorgMapper">

    <select id="queryUserMasterorg" parameterType="java.util.HashMap"  resultType="java.util.HashMap">
        select  org  from user_masterorg
        <where>
            user_id = #{user_id,jdbcType=VARCHAR}  and  ytenant_id = #{ytenant_id} and billnum = #{billnum}
        </where>
    </select>


    <insert id="addUserMasterorg"  parameterType="java.util.HashMap">
        insert  into   user_masterorg (id,user_id,billnum,tenant_id,ytenant_id,org) values
         (#{id},#{user_id,jdbcType=VARCHAR},#{billnum},#{tenant_id,jdbcType=VARCHAR},#{ytenant_id},#{org})

    </insert>

    <delete id="delUserMasterorg" parameterType="java.util.HashMap">
        delete  from  user_masterorg
        <where>
            user_id = #{user_id,jdbcType=VARCHAR}  and  ytenant_id = #{ytenant_id} and billnum = #{billnum}
        </where>
    </delete>








</mapper>
