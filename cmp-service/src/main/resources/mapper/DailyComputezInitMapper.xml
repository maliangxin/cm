    <!-- 日记账分页 期初重算-->
    <select id="getJournalReInitData" parameterType = "java.util.HashMap" resultType="java.util.HashMap">
        select sum(lucy.debitnatSum) as debitnatSum,sum(lucy.debitoriSum) as debitoriSum,sum(lucy.creditnatSum) as creditnatSum,sum(lucy.creditoriSum) as creditoriSum
        from
           (select debitnatSum,debitoriSum,creditnatSum,creditoriSum
            from cmp_journal
            where ytenant_id = #{ytenantId}
                and  initflag = 0
            <if test = "parentAccentity !=null">
                and parentAccentity = #{parentAccentity}
            </if>
            <if test = "useAccentity !=null">
                and accentity = #{useAccentity}
            </if>
            <if test = "cashaccount !=null">
                and cashaccount = #{cashaccount}
            </if>
            <if test = "bankaccount !=null">
                and bankaccount = #{bankaccount}
            </if>
            <if test = "currency !=null">
                and currency = #{currency}
            </if>
            <if test = "billDateStart!=null and billDateEnd!=null">
                and vouchdate &gt;= #{billDateStart} and vouchdate &lt;= #{billDateEnd}
            </if>
            <if test = "dzstartdate!=null and dzenddate!=null">
                and dzdate &gt;= #{dzstartdate} and dzdate &lt;= #{dzenddate}
            </if>
            <if test = "auditstatus !=null and auditstatus==2">
                and auditstatus=1
            </if>
            <if test = "settlestatus !=null and settlestatus==2">
                and settlestatus=2
            </if>
            <if test = "customer !=null">
                and customer in
                <foreach item="item" index="index" collection="customer" open="("
                         separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test = "supplier !=null">
                and supplier in
                <foreach item="item" index="index" collection="supplier" open="("
                         separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test = "employee !=null">
                and employee in
                <foreach item="item" index="index" collection="employee" open="("
                         separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test = "dept !=null">
                and dept in
                <foreach item="item" index="index" collection="dept" open="("
                         separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test = "project !=null">
                and project in
                <foreach item="item" index="index" collection="project" open="("
                         separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test = "topsrcitem !=null">
                and topsrcitem in
                <foreach item="item" index="index" collection="topsrcitem" open="("
                         separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test = "topbilltype !=null">
                and topbilltype in
                <foreach item="item" index="index" collection="topbilltype" open="("
                         separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test = "dzorder !=null and dzorder==false">
                order by vouchdate,
                <if test = "journalBalanceSortRule != null and journalBalanceSortRule == 1">
                    ISNULL(rptype),rptype,
                </if>
                id asc limit #{limit}) lucy
            </if>
            <if test = "dzorder !=null and dzorder==true">
                order by ISNULL(dzdate),dzdate,
                <if test = "journalBalanceSortRule == null or journalBalanceSortRule == 0">
                    ISNULL(dztime),dztime,
                </if>
                <if test = "journalBalanceSortRule != null and journalBalanceSortRule == 1">
                    ISNULL(rptype),rptype,ISNULL(dztime),dztime,
                </if>
                id limit #{limit}) lucy
            </if>

    </select>

