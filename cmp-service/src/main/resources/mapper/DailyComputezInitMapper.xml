    <!-- 模拟日结相关计算sql 修正昨日今日余额-->
    <select id="getJournalListForRevise" parameterType = "java.util.HashMap" resultType="java.util.HashMap">
        select  sum(creditoriSum) creditoriSum,sum(debitoriSum) debitoriSum,sum(creditnatSum) creditnatSum,sum(debitnatSum)debitnatSum,bankaccount,cashaccount,currency
        <if test = "parentAccentity !=null">
            ,parentAccentity
        </if>
        <if test = "useAccentity !=null">
            ,accentity
        </if>
        from  cmp_journal
        where
            ytenant_id = #{ytenantId}
        <if test = "parentAccentity !=null">
            and parentAccentity = #{parentAccentity}
        </if>
        <if test = "useAccentity !=null">
            and accentity = #{useAccentity}
        </if>
        <if test = "cashaccounts !=null">
            and cashaccount in
            <foreach item="item" index="index" collection="cashaccounts" open="("
                     separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test = "bankaccounts !=null">
            and bankaccount in
            <foreach item="item" index="index" collection="bankaccounts" open="("
                     separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test = "currencys !=null">
            and currency in
            <foreach item="item" index="index" collection="currencys" open="("
                     separator="," close=")">
                #{item}
            </foreach>
        </if>
        and settlestatus = 1
        and initflag = 0
        <if test = "auditstatus !=null and auditstatus == 2">
            and auditstatus = 1
        </if>
        <if test = "maxDateSettlement !=null">
            and ((dzdate is null and vouchdate &lt;= #{maxDateSettlement}) or dzdate &lt;= #{maxDateSettlement})
        </if>
        <if test = "maxDateSettlement ==null and endDate!=null">
            and ((dzdate is null and vouchdate &lt;= #{endDate}) or dzdate &lt;= #{endDate})
        </if>
        GROUP BY bankaccount,cashaccount,currency
        <if test = "parentAccentity !=null">
            ,parentAccentity
        </if>
        <if test = "useAccentity !=null">
            ,accentity
        </if>
    </select>


    <!-- 模拟日结相关计算sql 进行余额计算-->
    <select id="getJournalListForCount" parameterType = "java.util.HashMap" resultType="java.util.HashMap">
        select  sum(creditoriSum) creditoriSum,sum(debitoriSum) debitoriSum,sum(creditnatSum) creditnatSum,sum(debitnatSum)debitnatSum,bankaccount,cashaccount,currency
        <if test = "parentAccentity !=null">
            ,parentAccentity
        </if>
        ,accentity
        from  cmp_journal
        where
        ytenant_id = #{ytenantId}
        <if test = "parentAccentity !=null">
            and parentAccentity = #{parentAccentity}
        </if>
        <if test = "useAccentity !=null">
            and accentity = #{useAccentity}
        </if>
        <if test = "cashaccounts !=null and bankaccounts == null">
            and cashaccount in
            <foreach item="item" index="index" collection="cashaccounts" open="("
                     separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test = "bankaccounts !=null and cashaccounts == null">
            and bankaccount in
            <foreach item="item" index="index" collection="bankaccounts" open="("
                     separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test = "bankaccounts !=null and cashaccounts != null">
            and (bankaccount in
            <foreach item="item" index="index" collection="bankaccounts" open="("
                     separator="," close=")">
                #{item}
            </foreach>
            or cashaccount in
            <foreach item="item" index="index" collection="cashaccounts" open="("
                     separator="," close=")">
                #{item}
            </foreach>)
        </if>
        <if test = "currencys !=null">
            and currency in
            <foreach item="item" index="index" collection="currencys" open="("
                     separator="," close=")">
                #{item}
            </foreach>
        </if>
        and initflag = 0
        <if test = "maxDateSettlement !=null">
            and ((dzdate is null and vouchdate &gt;= #{maxDateSettlement}) or dzdate &gt;= #{maxDateSettlement})
        </if>
        <if test = "endDate !=null and auditstatus !=null and auditstatus==2 and settlestatus !=null and settlestatus==2">
            and  dzdate &lt;= CAST(#{endDate} AS DATE)
        </if>
        <if test = "endDate !=null and auditstatus !=null and auditstatus==1 and settlestatus !=null and settlestatus==1">
            and  vouchdate &lt;= CAST(#{endDate} AS DATE)
        </if>
        <if test = "endDate !=null and auditstatus !=null and auditstatus==2 and settlestatus !=null and settlestatus==1">
            and  vouchdate &lt;= CAST(#{endDate} AS DATE)
        </if>
        <if test = "auditstatus !=null and auditstatus==2">
            and auditstatus=1
        </if>
        <if test = "settlestatus !=null and settlestatus==2">
            and settlestatus=2
        </if>

        GROUP BY bankaccount,cashaccount,currency
        <if test = "parentAccentity !=null">
            ,parentAccentity
        </if>
            ,accentity
    </select>

